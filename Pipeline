import pandas as pd

input_path = "Data/Aqi_1hr.xlsx"

# load file; read_excel for Excel, read_csv for CSV
if input_path.lower().endswith((".xlsx", ".xls")):
    df = pd.read_excel(input_path)
else:
    df = pd.read_csv(input_path, encoding="utf-8", on_bad_lines="skip")

# normalize column names
df.columns = df.columns.str.strip()

# combine Date and time_ist into a proper datetime column
df["Datetime"] = pd.to_datetime(
    df["Date"].astype(str).str.strip() + " " + df["time_ist"].astype(str).str.strip(),
    format="%d-%m-%Y %H:%M:%S",
    errors="coerce"
)

# drop rows where datetime conversion failed, then sort by the new datetime
df = df.dropna(subset=["Datetime"]).sort_values("Datetime").reset_index(drop=True)

# save cleaned output to a new CSV file
output_path = "Data/Aqi_1hrtimeseries.csv"
df.to_csv(output_path, index=False)
print(f"Saved cleaned data to {output_path}")

# verify result
print(df[["Date", "time_ist", "Datetime"]].head())
print(df.shape)

