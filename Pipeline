import pandas as pd

# =========================
# FILE NAMES
# =========================
govt_file = "Govtaqi.csv"
base_file = "Data/step3_openmeteo_merged.csv"
output_file = "Data/step3a_weathergovt_merged.csv"

# =========================
# LOAD FILES
# =========================
govt_df = pd.read_csv(govt_file)
base_df = pd.read_csv(base_file)

# =========================
# MAKE DATETIME COLUMNS
# =========================
# Govt file: assumes Date + time_ist already exist
if "Datetime" not in govt_df.columns:
    govt_df["Datetime"] = pd.to_datetime(
        govt_df["Date"].astype(str).str.strip() + " " + govt_df["time_ist"].astype(str).str.strip(),
        errors="coerce",
        dayfirst=True
    )
else:
    govt_df["Datetime"] = pd.to_datetime(govt_df["Datetime"], errors="coerce", dayfirst=True)

# Base file: Open-Meteo merged file
base_df["Datetime"] = pd.to_datetime(base_df["Datetime"], errors="coerce", dayfirst=True)

# drop bad rows
govt_df = govt_df.dropna(subset=["Datetime"]).sort_values("Datetime").reset_index(drop=True)
base_df = base_df.dropna(subset=["Datetime"]).sort_values("Datetime").reset_index(drop=True)

# =========================
# SHIFT GOVT TIMELINE TO MATCH BASE FILE START
# =========================
govt_start = govt_df["Datetime"].min()
base_start = base_df["Datetime"].min()

time_shift = base_start - govt_start
govt_df["Datetime_shifted"] = govt_df["Datetime"] + time_shift

print("Govt start:", govt_start)
print("Base start:", base_start)
print("Applied shift:", time_shift)

# =========================
# KEEP ONLY GOVT AQI COLUMNS
# =========================
# rename these if your actual govt columns differ
possible_cols = {
    "pm2_5_api": "pm2_5_govt",
    "pm10_api": "pm10_govt",
    "no2_api": "no2_govt",
    "co_api": "co_govt",
    "aqi_index_api": "aqi_index_govt",
    "pm2_5": "pm2_5_govt",
    "pm10": "pm10_govt",
    "no2": "no2_govt",
    "co": "co_govt",
    "aqi_index": "aqi_index_govt"
}

govt_keep = ["Datetime_shifted"]
rename_map = {}

for old_col, new_col in possible_cols.items():
    if old_col in govt_df.columns:
        govt_keep.append(old_col)
        rename_map[old_col] = new_col

govt_small = govt_df[govt_keep].copy().rename(columns=rename_map)
govt_small = govt_small.rename(columns={"Datetime_shifted": "Datetime"})

# =========================
# MERGE
# =========================
merged_df = pd.merge(
    base_df,
    govt_small,
    on="Datetime",
    how="left"
)

# =========================
# SAVE
# =========================
merged_df.to_csv(output_file, index=False)
print(f"Saved: {output_file}")
print(merged_df.head())
print(merged_df.shape)