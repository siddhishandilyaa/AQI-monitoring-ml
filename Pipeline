#Step3
import pandas as pd
import numpy as np
from openpyxl import load_workbook

# ========= FILE PATHS =========
input_file = "Data/step2_timeline.xlsx"
output_file = "Data/Step3_filledvalues.xlsx"

# ========= READ FILE =========
df = pd.read_excel(input_file)

# ========= CLEAN COLUMN NAMES =========
df.columns = [str(c).strip() for c in df.columns]

# ========= REMOVE EXTRA DATE/TIME COLUMNS =========
# since Datetime already contains both date + time
df.drop(columns=["Date", "time_ist"], inplace=True, errors="ignore")

# ========= COLUMN NAMES =========
datetime_col = "Datetime"
pollutant_cols = ["aqi_index", "pm2_5", "pm10", "co", "no2"]

# weather columns only for reference, untouched
leave_untouched = ["temp_c", "humidity", "pressure_mb", "windspeed_kph", "condition"]

# ========= CHECK REQUIRED COLUMNS =========
for col in [datetime_col] + pollutant_cols:
    if col not in df.columns:
        raise ValueError(f"Column not found: {col}")

# ========= DATETIME PARSING =========
df[datetime_col] = pd.to_datetime(df[datetime_col], errors="coerce")
df["hour"] = df[datetime_col].dt.hour

# ========= KEEP ORIGINAL FOR MISSING MASK =========
original_df = pd.read_excel(input_file)
original_df.columns = [str(c).strip() for c in original_df.columns]
original_df.drop(columns=["Date", "time_ist"], inplace=True, errors="ignore")

# ========= HELPER: TIME-OF-DAY BIAS =========
def get_bias(hour, col):
    if pd.isna(hour):
        return 0.0

    # Late night / early morning
    if 0 <= hour <= 5:
        bias_map = {
            "aqi_index": -0.015,
            "pm2_5": -0.018,
            "pm10": -0.015,
            "co": -0.020,
            "no2": -0.018
        }

    # Morning build-up
    elif 6 <= hour <= 9:
        bias_map = {
            "aqi_index": 0.010,
            "pm2_5": 0.012,
            "pm10": 0.010,
            "co": 0.008,
            "no2": 0.012
        }

    # Afternoon dispersion
    elif 10 <= hour <= 16:
        bias_map = {
            "aqi_index": -0.005,
            "pm2_5": -0.008,
            "pm10": -0.006,
            "co": -0.004,
            "no2": -0.005
        }

    # Evening rise
    elif 17 <= hour <= 21:
        bias_map = {
            "aqi_index": 0.012,
            "pm2_5": 0.015,
            "pm10": 0.013,
            "co": 0.014,
            "no2": 0.016
        }

    else:
        bias_map = {c: 0.0 for c in pollutant_cols}

    return bias_map.get(col, 0.0)

# ========= STEP 1: BASE INTERPOLATION =========
for col in pollutant_cols:
    df[col] = pd.to_numeric(df[col], errors="coerce")
    df[col] = df[col].interpolate(method="linear", limit_direction="both")

# ========= STEP 2: TIME-AWARE ADJUSTMENT ONLY ON ORIGINAL NaNs =========
for col in pollutant_cols:
    original_missing = pd.to_numeric(original_df[col], errors="coerce").isna()

    for i in df.index[original_missing]:
        hour = df.at[i, "hour"]
        base_val = df.at[i, col]

        if pd.isna(base_val):
            continue

        prev_val = df.at[i - 1, col] if i - 1 in df.index else base_val
        next_val = df.at[i + 1, col] if i + 1 in df.index else base_val
        local_trend = ((prev_val + next_val) / 2) - base_val

        bias = get_bias(hour, col)

        noise_scale = max(abs(base_val) * 0.01, 0.5)
        noise = np.random.uniform(-noise_scale, noise_scale) * 0.35

        adjusted = base_val * (1 + bias) + 0.2 * local_trend + noise
        df.at[i, col] = adjusted

# ========= STEP 3: ENFORCE RELATIONS =========
# pm10 should usually be >= pm2_5
for i in df.index:
    if pd.notna(df.at[i, "pm2_5"]) and pd.notna(df.at[i, "pm10"]):
        if df.at[i, "pm10"] < df.at[i, "pm2_5"]:
            df.at[i, "pm10"] = df.at[i, "pm2_5"] + np.random.uniform(2, 8)

# AQI softly follows PM trend
for i in df.index:
    if pd.notna(df.at[i, "pm2_5"]) and pd.notna(df.at[i, "pm10"]):
        pm25 = df.at[i, "pm2_5"]
        pm10 = df.at[i, "pm10"]

        estimated_aqi = 0.55 * pm25 + 0.35 * pm10 + 60
        current_aqi = df.at[i, "aqi_index"]

        if pd.notna(current_aqi):
            df.at[i, "aqi_index"] = 0.7 * current_aqi + 0.3 * estimated_aqi

# ========= STEP 4: SMOOTH FILLED PARTS ONLY =========
for col in pollutant_cols:
    original_missing = pd.to_numeric(original_df[col], errors="coerce").isna()
    smooth_series = df[col].rolling(window=3, center=True, min_periods=1).mean()

    for i in df.index[original_missing]:
        df.at[i, col] = 0.6 * df.at[i, col] + 0.4 * smooth_series.at[i]

# ========= STEP 5: CLIP NEGATIVE VALUES =========
for col in pollutant_cols:
    df[col] = df[col].clip(lower=0)

# ========= STEP 6: ROUND TO 2 DECIMALS =========
for col in pollutant_cols:
    df[col] = df[col].round(2)

# ========= DROP TEMP HOUR COLUMN =========
df.drop(columns=["hour"], inplace=True)

# ========= SAVE TO EXCEL =========
df.to_excel(output_file, index=False)

# ========= AUTO-INCREASE COLUMN WIDTH =========
wb = load_workbook(output_file)
ws = wb.active

for col in ws.columns:
    max_length = 0
    col_letter = col[0].column_letter

    for cell in col:
        try:
            if cell.value is not None:
                max_length = max(max_length, len(str(cell.value)))
        except:
            pass

    ws.column_dimensions[col_letter].width = max_length + 2

wb.save(output_file)

print(f"Done. Saved file as: {output_file}")

