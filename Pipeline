import pandas as pd
import numpy as np
from openpyxl import load_workbook

# ==========================================
# FILE PATHS
# ==========================================
input_file = "Data/Step4a_merged.xlsx"
output_file = "Data/Final_merged.xlsx"

# ==========================================
# READ FILE
# ==========================================
df = pd.read_excel(input_file)
df.columns = [str(c).strip() for c in df.columns]

# ==========================================
# REQUIRED COLUMNS
# ==========================================
required_cols = [
    "pm2_5", "pm2_5_govt",
    "pm10", "pm10_govt",
    "co", "co_govt",
    "no2", "no2_govt"
]

for col in required_cols:
    if col not in df.columns:
        raise ValueError(f"Missing column: {col}")

# ==========================================
# MAKE NUMERIC
# ==========================================
for col in required_cols:
    df[col] = pd.to_numeric(df[col], errors="coerce")

# ==========================================
# BOUNDED MERGE FUNCTION
# ==========================================
def bounded_merge(sensor, govt, col):
    if pd.isna(sensor) and pd.notna(govt):
        return govt

    if pd.notna(sensor) and pd.isna(govt):
        return sensor

    if pd.isna(sensor) and pd.isna(govt):
        return np.nan

    diff = govt - sensor

    # small correction fraction
    merged = sensor + 0.15 * diff

    # hard caps so value doesn't jump unrealistically
    if col == "pm2_5":
        merged = max(min(merged, sensor + 15), sensor - 15)

    elif col == "pm10":
        merged = max(min(merged, sensor + 18), sensor - 18)

    elif col == "co":
        merged = max(min(merged, sensor + 120), sensor - 120)

    elif col == "no2":
        merged = max(min(merged, sensor + 8), sensor - 8)

    return merged

# ==========================================
# CREATE MERGED COLUMNS
# ==========================================
df["pm2_5_merge"] = [
    bounded_merge(s, g, "pm2_5")
    for s, g in zip(df["pm2_5"], df["pm2_5_govt"])
]

df["pm10_merge"] = [
    bounded_merge(s, g, "pm10")
    for s, g in zip(df["pm10"], df["pm10_govt"])
]

df["co_merge"] = [
    bounded_merge(s, g, "co")
    for s, g in zip(df["co"], df["co_govt"])
]

df["no2_merge"] = [
    bounded_merge(s, g, "no2")
    for s, g in zip(df["no2"], df["no2_govt"])
]

# ==========================================
# OPTIONAL CONTINUITY SMOOTHING
# prevents sudden hour-to-hour jump
# ==========================================
def smooth_series(series, max_step):
    values = series.copy().tolist()

    for i in range(1, len(values)):
        prev = values[i - 1]
        curr = values[i]

        if pd.notna(prev) and pd.notna(curr):
            if curr > prev + max_step:
                values[i] = prev + max_step
            elif curr < prev - max_step:
                values[i] = prev - max_step

    return pd.Series(values, index=series.index)

df["pm2_5_merge"] = smooth_series(df["pm2_5_merge"], max_step=20)
df["pm10_merge"] = smooth_series(df["pm10_merge"], max_step=22)
df["co_merge"] = smooth_series(df["co_merge"], max_step=150)
df["no2_merge"] = smooth_series(df["no2_merge"], max_step=10)

# ==========================================
# AQI CALCULATION FROM MERGED PM VALUES
# CPCB breakpoint logic
# ==========================================
def calc_subindex_pm25(c):
    if pd.isna(c):
        return None

    bp = [
        (0, 30, 0, 50),
        (31, 60, 51, 100),
        (61, 90, 101, 200),
        (91, 120, 201, 300),
        (121, 250, 301, 400),
        (251, 1000, 401, 500),
    ]

    for blo, bhi, ilo, ihi in bp:
        if blo <= c <= bhi:
            return ((ihi - ilo) / (bhi - blo)) * (c - blo) + ilo
    return None

def calc_subindex_pm10(c):
    if pd.isna(c):
        return None

    bp = [
        (0, 50, 0, 50),
        (51, 100, 51, 100),
        (101, 250, 101, 200),
        (251, 350, 201, 300),
        (351, 430, 301, 400),
        (431, 1000, 401, 500),
    ]

    for blo, bhi, ilo, ihi in bp:
        if blo <= c <= bhi:
            return ((ihi - ilo) / (bhi - blo)) * (c - blo) + ilo
    return None

def final_aqi(pm25, pm10):
    aqi25 = calc_subindex_pm25(pm25)
    aqi10 = calc_subindex_pm10(pm10)

    vals = [v for v in [aqi25, aqi10] if v is not None]
    return max(vals) if vals else np.nan

df["aqi_merge"] = [
    final_aqi(pm25, pm10)
    for pm25, pm10 in zip(df["pm2_5_merge"], df["pm10_merge"])
]

# ==========================================
# CONDITION TEXT FROM MERGED AQI
# ==========================================
def get_condition(aqi):
    if pd.isna(aqi):
        return ""
    elif aqi <= 50:
        return "Good"
    elif aqi <= 100:
        return "Satisfactory"
    elif aqi <= 200:
        return "Moderate"
    elif aqi <= 300:
        return "Poor"
    elif aqi <= 400:
        return "Very Poor"
    else:
        return "Severe"

df["condition_text_merge"] = df["aqi_merge"].apply(get_condition)

# ==========================================
# ROUND
# ==========================================
round_cols = [
    "pm2_5_merge", "pm10_merge", "co_merge", "no2_merge", "aqi_merge"
]
for col in round_cols:
    df[col] = pd.to_numeric(df[col], errors="coerce").round(2)

# ==========================================
# SAVE
# ==========================================
df.to_excel(output_file, index=False)

# ==========================================
# AUTO COLUMN WIDTH
# ==========================================
wb = load_workbook(output_file)
ws = wb.active

for col_cells in ws.columns:
    max_len = 0
    col_letter = col_cells[0].column_letter
    for cell in col_cells:
        if cell.value is not None:
            max_len = max(max_len, len(str(cell.value)))
    ws.column_dimensions[col_letter].width = max_len + 2

wb.save(output_file)

print(f"Done. Saved file as: {output_file}")