import pandas as pd
import numpy as np
from openpyxl import load_workbook

# =========================================================
# FILE PATHS
# =========================================================
main_file = "Data/Step3_filledvalues.xlsx"
weather_file = "Pressure.xlsx"
output_file = "Data/Step4_pressure.xlsx"

# =========================================================
# READ FILES
# =========================================================
main_df = pd.read_excel(main_file)
weather_df = pd.read_excel(weather_file)

main_df.columns = [str(c).strip() for c in main_df.columns]
weather_df.columns = [str(c).strip() for c in weather_df.columns]

# =========================================================
# DATETIME PARSING
# =========================================================
main_df["Datetime"] = pd.to_datetime(main_df["Datetime"], errors="coerce")
weather_df["time"] = pd.to_datetime(weather_df["time"], dayfirst=True, errors="coerce")

# =========================================================
# 🔥 IMPORTANT: MERGE BY MONTH-DAY-HOUR (2025 vs 2026 issue)
# =========================================================
main_df["merge_key"] = main_df["Datetime"].dt.strftime("%m-%d %H:%M:%S")
weather_df["merge_key"] = weather_df["time"].dt.strftime("%m-%d %H:%M:%S")

# rename weather columns
weather_df = weather_df.rename(columns={
    "temp_c": "temp_ref",
    "humidity": "humidity_ref",
    "windspeed_kph": "wind_ref"
})

weather_df = weather_df[["merge_key", "temp_ref", "humidity_ref", "wind_ref"]]

# merge
df = main_df.merge(weather_df, on="merge_key", how="left")

# =========================================================
# 🎯 SMALL CORRECTION FUNCTION (NO FAKE JUMPS)
# =========================================================
def small_correction(sensor, ref, col):
    if pd.isna(sensor) and pd.notna(ref):
        return ref  # fill blank directly

    if pd.notna(sensor) and pd.notna(ref):
        diff = ref - sensor

        # VERY SMALL influence (2–5%)
        corrected = sensor + 0.02 * diff

        # HARD LIMITS (prevent unrealistic jump)
        if col == "temp_c":
            corrected = max(min(corrected, sensor + 1), sensor - 1)

        elif col == "humidity":
            corrected = max(min(corrected, sensor + 5), sensor - 5)

        elif col == "windspeed_kph":
            corrected = max(min(corrected, sensor + 2), sensor - 2)

        return corrected

    return sensor

# =========================================================
# APPLY CORRECTION
# =========================================================
cols_map = {
    "temp_c": "temp_ref",
    "humidity": "humidity_ref",
    "windspeed_kph": "wind_ref"
}

for col, ref_col in cols_map.items():
    df[col] = pd.to_numeric(df[col], errors="coerce")
    df[ref_col] = pd.to_numeric(df[ref_col], errors="coerce")

    new_vals = []

    for i in range(len(df)):
        sensor = df.loc[i, col]
        ref = df.loc[i, ref_col]

        new_val = small_correction(sensor, ref, col)

        # 🔥 EXTRA: continuity smoothing (neighbor check)
        if i > 0 and pd.notna(new_val):
            prev = df.loc[i - 1, col]
            if pd.notna(prev):
                # don't allow jump > threshold
                if col == "temp_c":
                    new_val = max(min(new_val, prev + 1), prev - 1)

                elif col == "humidity":
                    new_val = max(min(new_val, prev + 6), prev - 6)

                elif col == "windspeed_kph":
                    new_val = max(min(new_val, prev + 2), prev - 2)

        new_vals.append(new_val)

    df[col] = new_vals

# =========================================================
# ROUND VALUES
# =========================================================
for col in ["temp_c", "humidity", "windspeed_kph"]:
    df[col] = pd.to_numeric(df[col], errors="coerce").round(2)

# =========================================================
# CLEANUP
# =========================================================
df.drop(columns=["merge_key", "temp_ref", "humidity_ref", "wind_ref"], inplace=True)

# =========================================================
# SAVE
# =========================================================
df.to_excel(output_file, index=False)

# =========================================================
# AUTO COLUMN WIDTH
# =========================================================
wb = load_workbook(output_file)
ws = wb.active

for col_cells in ws.columns:
    max_len = 0
    col_letter = col_cells[0].column_letter
    for cell in col_cells:
        if cell.value is not None:
            max_len = max(max_len, len(str(cell.value)))
    ws.column_dimensions[col_letter].width = max_len + 2

wb.save(output_file)

print(f"Done. Saved file as: {output_file}")

