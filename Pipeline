import requests
import pandas as pd

LAT = 28.7041
LON = 77.1025

START_DATE = "2026-01-04"
END_DATE = "2026-03-03"

url = "https://archive-api.open-meteo.com/v1/archive"

params = {
    "latitude": LAT,
    "longitude": LON,
    "start_date": START_DATE,
    "end_date": END_DATE,
    "hourly": "temperature_2m,relativehumidity_2m,windspeed_10m,surface_pressure,weathercode",
    "timezone": "Asia/Kolkata"
}

response = requests.get(url, params=params)
data = response.json()

api_df = pd.DataFrame({
    "Datetime": data["hourly"]["time"],
    "temp_c_api": data["hourly"]["temperature_2m"],
    "humidity_api": data["hourly"]["relativehumidity_2m"],
    "pressure_api": data["hourly"]["surface_pressure"],
    "windspeed_kph_api": data["hourly"]["windspeed_10m"],
    "weathercode": data["hourly"]["weathercode"]
})

api_df["Datetime"] = pd.to_datetime(api_df["Datetime"])
def weathercode_to_text(code):
    if code == 0:
        return "Clear sky"
    elif code in [1, 2, 3]:
        return "Partly cloudy"
    elif code in [45, 48]:
        return "Fog"
    elif code in [51, 53, 55]:
        return "Drizzle"
    elif code in [61, 63, 65]:
        return "Rain"
    elif code in [80, 81, 82]:
        return "Rain showers"
    else:
        return "Unknown"

api_df["condition_text_api"] = api_df["weathercode"].apply(weathercode_to_text)

# drop weathercode
api_df = api_df.drop(columns=["weathercode"])
api_df.to_csv("step3a_openmeteo_hourly.csv", index=False)
print("Saved: step3a_openmeteo_hourly.csv")

